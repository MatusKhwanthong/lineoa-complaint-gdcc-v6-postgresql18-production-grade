NODE_ENV=production
PORT=3000
TRUST_PROXY=1
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=30000
SHUTDOWN_TIMEOUT_MS=15000
APP_BASE_URL=https://complaint.example.go.th
CORS_ORIGINS=https://complaint.example.go.th
PRIVACY_POLICY_URL=https://complaint.example.go.th/privacy.html
DATABASE_URL=postgresql://complaint_app:CHANGE_ME@10.0.20.10:5432/complaint_db
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=20
DB_STATEMENT_TIMEOUT_MS=15000
DB_IDLE_TRANSACTION_TIMEOUT_MS=15000
POSTGRES_REQUIRED_MAJOR=18
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_FILES=5
MAX_UPLOAD_MB=8
MAX_IMAGE_DIMENSION=1920
JPEG_QUALITY=85
GOOGLE_MAPS_API_KEY=
LIFF_ID=
LINE_LOGIN_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
JWT_SECRET=CHANGE_TO_RANDOM_SECRET_AT_LEAST_64_CHARACTERS
JWT_EXPIRES_IN=4h
DEV_BYPASS_LINE_AUTH=false
