NODE_ENV=development
PORT=3000
TRUST_PROXY=1

# URL สาธารณะของระบบ เช่น https://complaint.example.go.th
APP_BASE_URL=https://complaint.example.go.th
CORS_ORIGINS=https://complaint.example.go.th
PRIVACY_POLICY_URL=https://complaint.example.go.th/privacy.html

# PostgreSQL
DATABASE_URL=postgresql://complaint_app:CHANGE_ME@127.0.0.1:5432/complaint_db
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=10

# พื้นที่เก็บรูปภาพบน Web/API VM
# ระบบจริงแบบหลาย VM/หลาย Instance ควรเปลี่ยนเป็น Object Storage ที่หน่วยงานอนุมัติ
UPLOAD_DIR=./uploads
MAX_UPLOAD_FILES=5
MAX_UPLOAD_MB=8
MAX_IMAGE_DIMENSION=1920
JPEG_QUALITY=85

# Google Maps Platform
# ใช้แสดงแผนที่แบบฝังในหน้า Web App ต้องเปิด Maps Embed API
# คีย์นี้ถูกส่งไป Browser จึงต้องจำกัด HTTP referrer และจำกัดเฉพาะ API ที่ใช้
GOOGLE_MAPS_API_KEY=

# LINE Login / LIFF
LIFF_ID=2000000000-xxxxxxxx
LINE_LOGIN_CHANNEL_ID=2000000000

# LINE Official Account Messaging API
LINE_CHANNEL_SECRET=CHANGE_ME
LINE_CHANNEL_ACCESS_TOKEN=CHANGE_ME

# Admin JWT: สุ่มอย่างน้อย 32 ตัวอักษร
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=8h

# เปิดได้เฉพาะเครื่องพัฒนา ห้ามเปิดใน production
DEV_BYPASS_LINE_AUTH=false

POSTGRES_REQUIRED_MAJOR=18
